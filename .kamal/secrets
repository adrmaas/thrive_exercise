# Secrets are pulled from AWS SSM Parameter Store at deploy time.
# Requires AWS credentials with ssm:GetParameter on /thrive-exercise/* to be available.

KAMAL_REGISTRY_PASSWORD=$(aws ecr get-login-password --region us-west-2)
SECRET_KEY_BASE=$(aws ssm get-parameter --name /thrive-exercise/SECRET_KEY_BASE --with-decryption --query Parameter.Value --output text --region us-west-2)
USERNAME=$(aws ssm get-parameter --name /thrive-exercise/USERNAME --with-decryption --query Parameter.Value --output text --region us-west-2)
PASSWORD=$(aws ssm get-parameter --name /thrive-exercise/PASSWORD --with-decryption --query Parameter.Value --output text --region us-west-2)
