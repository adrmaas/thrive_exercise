# Secrets are pulled from AWS SSM Parameter Store when running locally.
# In CI, these are set as environment variables by the workflow and passed through directly.

KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:-$(aws ecr get-login-password --region us-west-2)}
SECRET_KEY_BASE=${SECRET_KEY_BASE:-$(aws ssm get-parameter --name /thrive-exercise/SECRET_KEY_BASE --with-decryption --query Parameter.Value --output text --region us-west-2)}
USERNAME=${USERNAME:-$(aws ssm get-parameter --name /thrive-exercise/USERNAME --with-decryption --query Parameter.Value --output text --region us-west-2)}
PASSWORD=${PASSWORD:-$(aws ssm get-parameter --name /thrive-exercise/PASSWORD --with-decryption --query Parameter.Value --output text --region us-west-2)}
